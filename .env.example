# App
APP_TITLE=Basic Sample App
APP_DESCRIPTION=Starting FastAPI and Rag from scratch
APP_VERSION=1.0.0
APP_ROOT_PATH=/icg
APP_SERVER_URL=http://127.0.0.1:8000
APP_SERVER_DESCRIPTION=Local development server
LOG_LEVEL=INFO

# Storage
UPLOAD_DIR=uploads
KNOWLEDGE_STORAGE_DIR=storage/knowledge_index
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=120

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_GENERATION_MODEL=gpt-5.4-mini
